# This environment variable is used in Production and Preview environments to deploy your Convex project
# This variable is not needed in development.
# You can create a Production or Preview deploy key at https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=

# WorkOS AuthKit — see WORKOS_SETUP.md
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Convex (from npx convex dev)
NEXT_PUBLIC_CONVEX_URL=

# Optional: higher Jupiter API rate limits (https://portal.jup.ag)
JUPITER_API_KEY=
